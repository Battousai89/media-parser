# Server
SERVER_PORT=8080
SERVER_MODE=debug

# Postgres
DB_HOST=postgres
DB_PORT=5432
DB_NAME=media_parser
DB_USER=media_parser_user
DB_PASSWORD=media_parser_password

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=media_parser_password

# RabbitMQ
RABBIT_HOST=rabbitmq
RABBIT_PORT=5672
RABBIT_UI_PORT=15672
RABBIT_USER=media_parser_user
RABBIT_PASSWORD=media_parser_password
RABBIT_VHOST=/media_parser

# Auth
API_KEYS=your-secret-api-key-here

# Parser
PARSER_WORKERS=5
BROWSER_HEADLESS=true
PAGE_LOAD_TIMEOUT=60
CACHE_TTL_HOURS=24

# YouTube Parser (yt-dlp)
YOUTUBE_ENABLED=true
YOUTUBE_TIMEOUT=30

# Minio
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin
MINIO_BUCKET=media-parser
MINIO_USE_SSL=false

# Robots.txt
IGNORE_ROBOTS_TXT=true
PARSER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36
