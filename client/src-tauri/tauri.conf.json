{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Media Parser",
  "version": "0.1.0",
  "identifier": "com.vital.media-parser",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Media Parser",
        "width": 1024,
        "height": 768,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "deb"],
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
